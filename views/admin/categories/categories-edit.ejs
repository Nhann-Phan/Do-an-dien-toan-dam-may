<%- include('../partials/header', { title: 'Sửa Danh mục' }) %>

<div class="flex min-h-screen">
    <%- include('../partials/sidebar', { page: 'categories' }) %>

    <main class="flex-1 p-10 bg-slate-50">
        <div class="max-w-xl mx-auto">
            <div class="flex items-center justify-between mb-8">
                <a href="/admin/categories" class="group flex items-center text-slate-400 hover:text-slate-800 text-sm font-bold transition">
                    <i class="bi bi-arrow-left-short text-xl mr-1 transition group-hover:-translate-x-1"></i> 
                    QUAY LẠI DANH SÁCH
                </a>
                <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest bg-white px-4 py-2 rounded-full border border-slate-100 shadow-sm">ID: <%= cat._id %></span>
            </div>
            
            <form action="/admin/categories/edit/<%= cat._id %>" method="POST" enctype="multipart/form-data" class="bg-white p-12 rounded-[3rem] shadow-2xl shadow-slate-200/50 border border-slate-100">
                <div class="flex items-center gap-5 mb-12">
                    <div class="p-4 bg-amber-100 text-amber-600 rounded-2xl shadow-lg shadow-amber-50">
                        <i class="bi bi-pencil-square text-2xl"></i>
                    </div>
                    <h2 class="text-3xl font-black text-slate-800 italic uppercase tracking-tighter">Sửa danh mục</h2>
                </div>
                
                <div class="space-y-10">
                    <div>
                        <label class="block text-[10px] font-black uppercase text-slate-400 mb-3 tracking-[0.2em]">Tên chuyên mục</label>
                        <input type="text" name="name" value="<%= cat.name %>" required 
                               class="w-full px-6 py-5 rounded-2xl bg-slate-50 border-none focus:ring-4 focus:ring-amber-50 focus:bg-white outline-none transition font-bold text-slate-700 uppercase italic">
                    </div>

                    <div class="p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100 flex items-center gap-8">
                        <div class="relative">
                            <img src="<%= cat.icon %>" class="w-20 h-20 object-contain rounded-2xl bg-white p-3 shadow-md border border-slate-200">
                            <div class="absolute -top-3 -right-3 bg-amber-500 text-white p-2 rounded-full shadow-lg">
                                <i class="bi bi-check-circle-fill"></i>
                            </div>
                        </div>
                        <div class="flex-1">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-1">Icon hiện tại</p>
                            <p class="text-[11px] text-slate-500 font-medium leading-relaxed italic">Nhân ơi, nếu không đổi icon thì cứ để trống phần upload ảnh bên dưới nhé.</p>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black uppercase text-slate-400 mb-3 tracking-[0.2em]">Thay icon mới (Nếu có)</label>
                        <div class="relative group">
                            <input type="file" name="icon" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                            <div class="w-full px-6 py-5 rounded-2xl bg-slate-50 border-2 border-dashed border-slate-200 group-hover:border-amber-400 group-hover:bg-amber-50 transition flex items-center justify-center space-x-3 text-slate-400 group-hover:text-amber-600">
                                <i class="bi bi-cloud-arrow-up text-2xl"></i>
                                <span class="text-sm font-black uppercase tracking-widest">Chọn ảnh mới</span>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="w-full py-6 bg-amber-500 text-white font-black rounded-3xl shadow-xl shadow-amber-100 hover:bg-amber-600 hover:-translate-y-1 active:scale-[0.98] transition transform uppercase tracking-[0.2em] text-sm">
                        Xác nhận thay đổi
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>

<!-- <%- include('../partials/footer') %> -->