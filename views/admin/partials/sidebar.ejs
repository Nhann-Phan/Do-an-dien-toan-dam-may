<aside class="w-72 bg-slate-900 min-h-screen sticky top-0 flex flex-col shadow-2xl z-50">
    <div class="p-8">
        <h1 class="text-2xl font-black text-white uppercase italic tracking-tighter">Admin <span class="text-red-500">TTC</span></h1>
    </div>

    <nav class="flex-1 px-4 space-y-2">
        <div class="pb-2 px-4 text-[10px] font-black text-slate-600 uppercase tracking-widest">Nội dung cá nhân</div>

        <a href="/admin" class="flex items-center space-x-3 px-4 py-3.5 <%= page === 'dashboard' ? 'bg-red-600 text-white shadow-lg shadow-red-900/20' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %> rounded-2xl font-bold transition">
            <i class="bi bi-grid-1x2-fill"></i>
            <span><%= (user && user.role === 'admin') ? 'TẤT CẢ BÀI VIẾT' : 'BÀI VIẾT CỦA TÔI' %></span>
        </a>

        <a href="/admin/comments" class="flex items-center space-x-3 px-4 py-3.5 <%= page === 'comments' ? 'bg-red-600 text-white shadow-lg shadow-red-900/20' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %> rounded-2xl font-bold transition">
            <i class="bi bi-chat-left-text-fill"></i>
            <span>BÌNH LUẬN</span>
        </a>

        <a href="/admin/profile" class="flex items-center space-x-3 px-4 py-3.5 <%= page === 'profile' ? 'bg-red-600 text-white shadow-lg shadow-red-900/20' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %> rounded-2xl font-bold transition">
            <i class="bi bi-person-bounding-box"></i>
            <span>HỒ SƠ CỦA TÔI</span>
        </a>

        <% if (user && user.role === 'admin') { %>
            <div class="pt-6 pb-2 px-4 text-[10px] font-black text-slate-600 uppercase tracking-widest border-t border-slate-800/50 mt-4">Quản trị hệ thống</div>
            
            <a href="/admin/categories" class="flex items-center space-x-3 px-4 py-3.5 <%= page === 'categories' ? 'bg-red-600 text-white shadow-lg shadow-red-900/20' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %> rounded-2xl font-bold transition">
                <i class="bi bi-folder2-open"></i>
                <span>DANH MỤC</span>
            </a>

            <a href="/admin/users" class="flex items-center space-x-3 px-4 py-3.5 <%= page === 'users' ? 'bg-red-600 text-white shadow-lg shadow-red-900/20' : 'text-slate-400 hover:bg-slate-800 hover:text-white' %> rounded-2xl font-bold transition">
                <i class="bi bi-people-fill"></i>
                <span>NGƯỜI DÙNG</span>
            </a>
        <% } %>

        <div class="pt-10 pb-4 px-4 text-[10px] font-black text-slate-600 uppercase tracking-widest border-t border-slate-800 mt-4">Hệ thống</div>

        <a href="/" target="_blank" class="flex items-center space-x-3 px-4 py-3.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-2xl font-bold transition">
            <i class="bi bi-browser-safari"></i>
            <span>XEM WEBSITE</span>
        </a>
        
        <a href="/auth/logout" class="flex items-center space-x-3 px-4 py-3.5 text-red-400 hover:bg-red-900/20 rounded-2xl font-bold transition">
            <i class="bi bi-box-arrow-right"></i>
            <span>ĐĂNG XUẤT</span>
        </a>
    </nav>

    <div class="p-6 border-t border-slate-800">
        <div class="flex items-center space-x-3 p-3 bg-slate-800/50 rounded-2xl border border-slate-700">
            <div class="w-10 h-10 bg-red-600 rounded-xl flex items-center justify-center font-black text-white italic shadow-lg shadow-red-900/20">
                <%= (user && user.username) ? user.username.charAt(0).toUpperCase() : '?' %>
            </div>
            <div class="overflow-hidden">
                <p class="text-xs font-black text-white truncate">
                    <%= (user && user.username) ? user.username : '' %>
                </p>
                <p class="text-[9px] text-slate-500 font-bold uppercase tracking-tighter">
                    <%= (user && user.role) ? user.role : 'Guest' %>
                </p>
            </div>
        </div>
    </div>
</aside>