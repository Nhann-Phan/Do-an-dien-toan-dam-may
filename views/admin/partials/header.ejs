<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <title><%= title %></title>
</head>
<div x-data="{ open: false }">
    <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-100 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between relative">
            <div class="flex items-center space-x-6">
                <a href="/" class="flex-shrink-0">
                    <img src="https://static.mediacdn.vn/tuoitre/web_images/logo-pc.png" class="h-12">
                </a>
                <button @click="open = !open" class="flex items-center space-x-2 p-2 hover:bg-slate-100 rounded-xl transition">
                    <div class="space-y-1.5">
                        <span class="block w-6 h-0.5 bg-slate-800 transition-transform" :class="open ? 'rotate-45 translate-y-2' : ''"></span>
                        <span class="block w-6 h-0.5 bg-slate-800 transition-opacity" :class="open ? 'opacity-0' : ''"></span>
                        <span class="block w-3 h-0.5 bg-slate-800 transition-transform" :class="open ? '-rotate-45 -translate-y-2 w-6' : ''"></span>
                    </div>
                    <span class="font-black text-xs uppercase tracking-widest text-slate-700 hidden md:block">Chuyên mục</span>
                </button>
            </div>

            <!-- <nav class="hidden lg:flex items-center space-x-10 text-[13px] font-black uppercase italic tracking-tighter text-slate-700">
                <a href="#" class="hover:text-red-600">XU HƯỚNG</a>
                <a href="#" class="hover:text-red-600">NỔI BẬT</a>
                <a href="#" class="hover:text-red-600">ĐỀ XUẤT</a>
            </nav> -->

            <div class="flex items-center space-x-4">
                <% if (typeof user !== 'undefined' && user) { %>
                    <div class="flex items-center space-x-3">
                        <span class="text-[10px] font-black uppercase text-slate-400">Chào, <%= user.fullName %></span>
                        <a href="/admin" class="bg-amber-400 hover:bg-amber-500 px-6 py-2 rounded-full font-black text-[11px] uppercase transition shadow-lg shadow-amber-100">
                            QUẢN LÝ
                        </a>
                        <a href="/auth/logout" class="text-[10px] font-black text-red-600 hover:underline uppercase">Thoát</a>
                    </div>
                <% } else { %>
                    <a href="/auth/login" class="bg-amber-400 hover:bg-amber-500 px-6 py-2 rounded-full font-black text-[11px] uppercase transition shadow-lg shadow-amber-100">
                        ĐĂNG TIN
                    </a>
                    <a href="/auth/register" class="text-[10px] font-black text-slate-400 hover:text-red-600 uppercase transition">Đăng ký</a>
                <% } %>
                
                    <form action="/search" method="GET" class="relative flex items-center group">
                        <input 
                            type="text" 
                            name="keyword" 
                            placeholder="Tìm gì đó..." 
                            class="bg-slate-100 rounded-full py-2 px-5 text-sm font-bold outline-none border-2 border-transparent focus:border-red-600 focus:w-64 w-40 transition-all duration-300 pr-12"
                        >
                        
                        <button type="submit" class="absolute right-1 p-2 hover:bg-slate-200 rounded-full transition text-slate-600">
                            <i class="bi bi-search text-xl"></i>
                        </button>
                    </form>            
            </div>

            <div x-show="open" @click.away="open = false" x-transition class="absolute top-full left-0 w-full bg-white border-b shadow-2xl p-8 z-40">
                <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6">
                    <% if (typeof categories !== 'undefined') { %>
                        <% categories.forEach(cat => { %>
                            <a href="/#<%= cat.name %>" @click="open = false" class="group flex items-center space-x-4 p-3 rounded-2xl hover:bg-slate-50 transition border border-transparent hover:border-slate-100">
                                <div class="w-12 h-12 rounded-full bg-white shadow-sm border border-slate-100 flex items-center justify-center group-hover:scale-110 transition duration-300 overflow-hidden">
                                    <img src="<%= cat.icon %>" class="w-8 h-8 object-contain">
                                </div>
                                <span class="font-black text-[11px] uppercase tracking-tighter text-slate-600 group-hover:text-red-600"><%= cat.name %></span>
                            </a>
                        <% }) %>
                    <% } %>
                </div>
            </div>
        </div>
    </header>
</div>