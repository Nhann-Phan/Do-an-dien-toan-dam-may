<div class="hidden">
    <%- include('partials/header', { title: 'Quản lý Bài viết' }) %>
</div>

<div class="flex min-h-screen">
    
    <%- include('partials/sidebar', { page: 'dashboard' }) %>

    <main class="flex-1 p-10 bg-slate-50">
        <header class="flex justify-between items-end mb-10">
            <div>
                <h2 class="text-xl font-black text-slate-800 tracking-tight uppercase italic">QUẢN LÝ BÀI VIẾT</h2>
                <p class="text-slate-500 text-sm mt-2 font-medium">Tổng số: <strong><%= articles.length %></strong> bài viết đang hiển thị</p>
            </div>
            <a href="/admin/add" class="group px-8 py-4 bg-red-600 text-white rounded-[1.5rem] font-black text-sm hover:bg-red-700 shadow-xl shadow-red-200 transition transform hover:-translate-y-1">
                <i class="bi bi-plus-lg mr-2"></i> THÊM TIN MỚI
            </a>
        </header>

        <div class="bg-white rounded-[2.5rem] shadow-2xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50/50 border-b border-slate-100 text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">
                    <tr>
                        <th class="p-7">Hình ảnh</th>
                        <th class="p-7">Tiêu đề</th>
                        <th class="p-7">Tác giả</th>
                        <th class="p-7 text-center">Chuyên mục</th>
                        <th class="p-7 text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% articles.forEach(article => { %>
                    <tr class="hover:bg-slate-50/30 transition group">
                        <td class="p-7">
                            <div class="relative w-20 h-20">
                                <img src="<%= article.image_url %>" class="w-full h-full rounded-2xl object-cover shadow-md group-hover:scale-105 transition duration-300">
                            </div>
                        </td>

                        <td class="p-7">
                            <h3 class="font-bold text-slate-800 text-base group-hover:text-red-600 transition truncate max-w-xs">
                                <%= article.title %>
                            </h3>
                        </td>

                        <td class="p-7">
                            <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest flex items-center">
                                <i class="bi bi-person-fill mr-1.5 text-slate-300"></i> <%= article.author %>
                            </p>
                        </td>

                        <td class="p-7 text-center">
                            <span class="px-4 py-1.5 bg-red-50 text-red-600 rounded-full text-[10px] font-black uppercase tracking-tighter">
                                <%= article.category %>
                            </span>
                        </td>

                        <td class="p-7 text-center">
                            <div class="flex justify-center items-center space-x-3">
                                <a href="/article/<%= article._id %>" target="_blank" 
                                class="w-10 h-10 flex items-center justify-center bg-blue-50 text-blue-500 rounded-xl hover:bg-blue-600 hover:text-white transition shadow-sm" title="Xem bài">
                                    <i class="bi bi-eye-fill"></i>
                                </a>

                                <% if (article.authorId && article.authorId.toString() === (user ? user.id : '')) { %>
                                    <a href="/admin/edit/<%= article._id %>" 
                                    class="w-10 h-10 flex items-center justify-center bg-amber-50 text-amber-500 rounded-xl hover:bg-amber-600 hover:text-white transition shadow-sm" title="Sửa bài">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                <% } else { %>
                                    <div class="w-10 h-10 flex items-center justify-center bg-slate-100 text-slate-300 rounded-xl cursor-not-allowed" title="Mày không phải tác giả bài này!">
                                        <i class="bi bi-lock-fill"></i>
                                    </div>
                                <% } %>

                                <% if (user.role === 'admin' || (article.authorId && article.authorId.toString() === user.id)) { %>
                                    <a href="/admin/delete/<%= article._id %>" 
                                    onclick="return confirm('Bạn chắc chắn muốn xóa bài này không?')" 
                                    class="w-10 h-10 flex items-center justify-center bg-red-50 text-red-500 rounded-xl hover:bg-red-600 hover:text-white transition shadow-sm" title="Xóa bài">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>

            <% if (articles.length === 0) { %>
            <div class="py-24 text-center bg-slate-50/20">
                <i class="bi bi-inbox text-5xl text-slate-200"></i>
                <p class="mt-4 text-slate-400 font-bold italic uppercase tracking-widest text-xs">Hệ thống chưa có bài viết mới</p>
            </div>
            <% } %>
        </div>
    </main>
</div> 

<div class="hidden">
<%- include('partials/footer') %>
</div>