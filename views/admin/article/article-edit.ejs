<%- include('../partials/header', { title: 'Chỉnh sửa bài viết' }) %>

<script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

<style>
    .ck-editor__editable { min-height: 400px !important; border-radius: 0 0 1.5rem 1.5rem !important; }
    .ck-toolbar { border-radius: 1.5rem 1.5rem 0 0 !important; border: none !important; background: #f8fafc !important; }
</style>

<div class="flex min-h-screen">
    <%- include('../partials/sidebar', { page: 'dashboard' }) %>

    <main class="flex-1 p-10 bg-slate-50">
        <div class="max-w-4xl mx-auto">
            <div class="flex items-center justify-between mb-8">
                <a href="/admin" class="text-slate-400 hover:text-slate-800 text-sm font-bold transition flex items-center group">
                    <i class="bi bi-arrow-left-short text-xl transition group-hover:-translate-x-1"></i> DANH SÁCH BÀI VIẾT
                </a>
                <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest bg-white px-4 py-2 rounded-full border border-slate-100 shadow-sm">ID: <%= article._id %></span>
            </div>
            
            <form action="/admin/edit/<%= article._id %>" method="POST" enctype="multipart/form-data" class="bg-white p-12 rounded-[3rem] shadow-2xl shadow-slate-200/50 border border-slate-100">
                <div class="flex items-center gap-5 mb-12">
                    <div class="p-4 bg-amber-100 text-amber-600 rounded-2xl shadow-lg shadow-amber-50">
                        <i class="bi bi-pencil-square text-2xl"></i>
                    </div>
                    <h2 class="text-3xl font-black text-slate-800 italic uppercase tracking-tighter">Cập nhật tin tức</h2>
                </div>
                
                <div class="space-y-10">
                    <div>
                        <label class="block text-[10px] font-black uppercase text-slate-400 mb-3 tracking-[0.2em]">Tiêu đề bài báo</label>
                        <input type="text" name="title" value="<%= article.title %>" required 
                               class="w-full px-6 py-5 rounded-2xl bg-slate-50 border-none focus:ring-4 focus:ring-amber-50 focus:bg-white outline-none transition font-bold text-slate-700 text-lg">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="block text-[10px] font-black uppercase text-slate-400 mb-3 tracking-[0.2em]">Chuyên mục</label>
                            <select name="category" required 
                                    class="w-full px-6 py-5 rounded-2xl bg-slate-50 border-none focus:ring-4 focus:ring-amber-50 outline-none transition font-bold text-slate-600 appearance-none cursor-pointer bg-white text-sm">
                                <% if (typeof cats !== 'undefined' && cats.length > 0) { %>
                                    <% cats.forEach(cat => { %>
                                        <option value="<%= cat.name %>" <%= article.category === cat.name ? 'selected' : '' %> class="font-bold uppercase">
                                            <%= cat.name %>
                                        </option>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>

                        <div>
                            <label class="block text-[10px] font-black uppercase text-slate-400 mb-3 tracking-[0.2em]">Thay ảnh mới</label>
                            <div class="relative group">
                                <input type="file" name="image" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10">
                                <div class="w-full px-6 py-5 rounded-2xl bg-slate-50 border-2 border-dashed border-slate-200 group-hover:border-amber-400 group-hover:bg-amber-50 transition flex items-center justify-center space-x-3 text-slate-400 group-hover:text-amber-600">
                                    <i class="bi bi-image-fill text-xl"></i>
                                    <span class="text-sm font-bold uppercase">Chọn ảnh khác</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="p-8 bg-slate-50 rounded-[2rem] border border-slate-100 flex items-center gap-8">
                        <div class="relative">
                            <img src="<%= article.image_url %>" class="w-32 h-32 object-cover rounded-3xl shadow-xl border-4 border-white">
                            <div class="absolute -top-3 -right-3 bg-amber-500 text-white p-2 rounded-full shadow-lg">
                                <i class="bi bi-cloud-check-fill"></i>
                            </div>
                        </div>
                        <div class="flex-1">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-2">Ảnh đang hiển thị</p>
                            <p class="text-xs text-slate-500 font-medium leading-relaxed italic">Nếu không chọn file mới, hệ thống sẽ tự động giữ nguyên tấm hình này.</p>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black uppercase text-slate-400 mb-3 tracking-[0.2em]">Tóm tắt ngắn</label>
                        <textarea name="summary" rows="2" 
                                  class="w-full px-6 py-5 rounded-2xl bg-slate-50 border-none focus:ring-4 focus:ring-amber-50 focus:bg-white outline-none transition font-medium text-slate-600"><%= article.summary %></textarea>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black uppercase text-slate-400 mb-3 tracking-[0.2em]">Nội dung chi tiết</label>
                        <textarea name="content" id="editor"><%= article.content %></textarea>
                    </div>

                    <button type="submit" class="w-full py-6 bg-amber-500 text-white font-black rounded-3xl shadow-2xl shadow-amber-100 hover:bg-amber-600 hover:-translate-y-1 active:scale-[0.98] transition transform uppercase tracking-[0.2em] text-sm">
                        Xác nhận và lưu thay đổi
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>

<script>
    ClassicEditor
        .create(document.querySelector('#editor'))
        .catch(error => { console.error(error); });
</script>
