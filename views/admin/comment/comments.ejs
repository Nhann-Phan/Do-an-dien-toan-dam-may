<div class="hidden">
<%- include('../partials/header') %>
</div>

<div class="flex min-h-screen">
    <%- include('../partials/sidebar', { page: 'comments' }) %>

    <main class="flex-1 p-10 bg-slate-50">
        
        <header class="flex justify-between items-end mb-10">
            <div>
                <h1 class="text-xl font-black italic uppercase tracking-tighter text-slate-800">Quản lý Bình luận</h1>
                <p class="text-slate-400 font-bold text-[10px] uppercase mt-2 tracking-widest">Kiểm duyệt gạch đá từ bạn đọc</p>
            </div>
        </header>

        <div class="bg-white rounded-[1.5rem] shadow-2xl shadow-slate-200/50 border border-slate-100 overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-900 text-white font-black text-[10px] uppercase tracking-[0.2em]">
                        <th class="px-8 py-6 w-1/6">Người gửi</th>
                        <th class="px-8 py-6 w-1/3">Nội dung</th>
                        <th class="px-8 py-6">Bài viết</th>
                        <th class="px-8 py-6">Ngày gửi</th>
                        <th class="px-8 py-6 text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    <% if (comments.length > 0) { %>
                        <% comments.forEach(cmt => { %>
                            <tr class="hover:bg-slate-50/80 transition group">
                                <td class="px-8 py-6">
                                    <div class="flex flex-col">
                                        <span class="font-black text-slate-700 text-sm uppercase"><%= cmt.authorName %></span>
                                        <span class="text-[9px] font-black tracking-tighter <%= cmt.authorRole !== 'guest' ? 'text-red-600' : 'text-slate-400' %> uppercase">
                                            <%= cmt.authorRole === 'guest' ? 'Khách' : cmt.authorRole %>
                                        </span>
                                    </div>
                                </td>
                                <td class="px-8 py-6">
                                    <p class="text-slate-600 text-sm leading-relaxed line-clamp-2 italic">"<%= cmt.content %>"</p>
                                </td>
                                <td class="px-8 py-6">
                                    <% if (cmt.articleId) { %>
                                        <a href="/article/<%= cmt.articleId._id %>" target="_blank" class="text-blue-500 hover:text-red-600 font-bold text-xs transition line-clamp-1">
                                            <%= cmt.articleId.title %>
                                        </a>
                                    <% } else { %>
                                        <span class="text-slate-300 text-xs italic">Bài viết đã bị xóa</span>
                                    <% } %>
                                </td>
                                <td class="px-8 py-6 text-[10px] font-mono font-bold text-slate-400">
                                    <%= cmt.createdAt.toLocaleString('vi-VN') %>
                                </td>
                                <td class="px-8 py-6 text-center">
                                    <a href="/admin/comments/delete/<%= cmt._id %>" 
                                       onclick="return confirm('Mày chắc chắn muốn trảm bình luận này không Nhân?')"
                                       class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-red-50 text-red-600 hover:bg-red-600 hover:text-white transition shadow-sm">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="px-8 py-20 text-center">
                                <p class="text-slate-400 italic font-bold">Chưa có bình luận mới</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>
</div>

<div class="hidden">
<%- include('../partials/footer') %>
</div>