<%- include('../admin/partials/header', { title: article.title }) %>

<style>
    /* Style cho nút khi ở trạng thái Active (Đã bấm) */
    .active-like { background-color: #fee2e2 !important; border-color: #fca5a5 !important; }
    .active-like i { color: #dc2626 !important; }
    .active-like span { color: #dc2626 !important; }

    .active-dislike { background-color: #f1f5f9 !important; border-color: #cbd5e1 !important; }
    .active-dislike i { color: #0f172a !important; }
    .active-dislike span { color: #0f172a !important; }
</style>

<body class="bg-slate-50 font-sans">
    <main class="max-w-7xl mx-auto px-4 py-12">
        
        <nav class="mb-10">
            <a href="/" class="text-red-600 font-black tracking-tighter uppercase text-sm hover:underline flex items-center">
                <i class="bi bi-arrow-left mr-2"></i> QUAY LẠI TRANG CHỦ
            </a>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            
            <article class="lg:col-span-8 bg-white p-8 lg:p-12 rounded-[3rem] shadow-2xl shadow-slate-200/50 border border-slate-100 order-1">    
                <div class="mb-8">
                    <% const currentCat = categories.find(c => c.name === article.category) %>
                    
                    <div class="flex items-center justify-center space-x-3 mb-6">
                        <% if (currentCat) { %>
                            <div class="w-14 h-14 rounded-full bg-white shadow-md border border-slate-100 flex items-center justify-center p-2 overflow-hidden">
                                <img src="<%= currentCat.icon %>" class="w-full h-full object-contain">
                            </div>
                        <% } %>
                        <span class="bg-red-50 text-red-600 px-4 py-1.5 rounded-full text-[13px] font-black uppercase tracking-widest">
                            <%= article.category %>
                        </span>
                    </div>

                    <h1 class="text-xl lg:text-xl font-black text-slate-900 mt-6 leading-[1.1] tracking-tight italic uppercase">
                        <%= article.title %>
                    </h1>

                    <div class="flex items-center justify-end space-x-4 mt-8 text-slate-400 text-[10px] font-black uppercase tracking-widest">
                        <span><i class="bi bi-person-fill"></i> Tác giả: <%= article.author %></span>
                        <span>•</span>
                        <span><i class="bi bi-calendar3"></i> <%= article.created_at.toLocaleDateString('vi-VN') %></span>
                    </div>
                </div>

                <div class="max-w-none">
                    <p class="text-xs font-bold text-slate-500 leading-relaxed mb-8 italic border-l-8 border-red-600 pl-6">
                        <%= article.summary %>
                    </p>
                    
                    <div class="text-l text-slate-800 leading-[1.9] max-w-none prose prose-red prose-img:rounded-3xl mb-12">
                        <%- article.content %>
                    </div>
                </div>

                <div class="flex items-center space-x-8 py-8 border-y border-slate-100 mb-10">
                    <div class="flex items-center space-x-2 text-slate-400">
                        <i class="bi bi-eye-fill text-xl"></i>
                        <span class="font-black text-xs uppercase tracking-widest"><%= article.views || 0 %> Lượt xem</span>
                    </div>

                    <button id="btn-like" onclick="handleVote('like')" class="flex items-center space-x-2 group outline-none">
                        <div id="icon-like" class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center transition shadow-sm border border-transparent">
                            <i class="bi bi-hand-thumbs-up-fill text-slate-400 transition text-lg"></i>
                        </div>
                        <span id="like-count" class="font-black text-slate-600 text-sm"><%= article.likes || 0 %></span>
                    </button>

                    <button id="btn-dislike" onclick="handleVote('dislike')" class="flex items-center space-x-2 group outline-none">
                        <div id="icon-dislike" class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center transition shadow-sm border border-transparent">
                            <i class="bi bi-hand-thumbs-down-fill text-slate-400 transition text-lg"></i>
                        </div>
                        <span id="dislike-count" class="font-black text-slate-600 text-sm"><%= article.dislikes || 0 %></span>
                    </button>
                </div>

                <section class="mt-10">
                    <h3 class="text-2xl font-black italic uppercase mb-8">Ý kiến bạn đọc</h3>
                    
                    <form action="/article/<%= article._id %>/comment" method="POST" class="mb-12">
                        <textarea name="content" required placeholder="Mày nghĩ gì về bài này?" 
                            class="w-full p-6 bg-slate-50 rounded-[2rem] border-none focus:ring-2 focus:ring-red-600 outline-none font-bold text-sm h-32"></textarea>
                        <button type="submit" class="mt-4 bg-red-600 text-white font-black px-8 py-3 rounded-full text-xs uppercase shadow-lg hover:scale-105 transition">Gửi ngay mạy</button>
                    </form>

                    <div class="space-y-6">
                        <% if (typeof comments !== 'undefined' && comments.length > 0) { %>
                            <% comments.forEach(cmt => { %>
                                <div class="bg-slate-50 p-6 rounded-[2rem] border border-transparent hover:border-slate-200 transition">
                                    <div class="flex items-center space-x-3 mb-2">
                                        <span class="font-black uppercase text-[10px] <%= cmt.authorRole !== 'guest' ? 'text-red-600' : 'text-slate-400' %>">
                                            <%= cmt.authorName %> <%= cmt.authorRole !== 'guest' ? '(Tác giả)' : '' %>
                                        </span>
                                    </div>
                                    <p class="text-slate-700 font-medium text-sm leading-relaxed"><%= cmt.content %></p>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-slate-400 italic text-sm text-center py-10 bg-slate-50 rounded-[2rem]">Chưa có bình luận nào. Mày mở bát đi Nhân!</p>
                        <% } %>
                    </div>
                </section>
            </article>

            <aside class="lg:col-span-4 space-y-8 order-2">
                <div class="sticky top-24">
                    <h3 class="text-xl font-black border-l-4 border-red-600 pl-4 uppercase italic mb-8 tracking-tighter text-slate-800">
                        Tin mới cập nhật
                    </h3>
                    <div class="space-y-6">
                        <% if (typeof latestArticles !== 'undefined') { %>
                            <% latestArticles.forEach(item => { %>
                                <a href="/article/<%= item._id %>" class="group flex gap-4 bg-white p-3 rounded-2xl shadow-sm hover:shadow-md transition border border-transparent hover:border-slate-100">
                                    <div class="w-20 h-20 flex-shrink-0 overflow-hidden rounded-xl">
                                        <img src="<%= item.image_url %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                                    </div>
                                    <div class="flex flex-col justify-center">
                                        <span class="text-[8px] font-black text-red-600 uppercase mb-1"><%= item.category %></span>
                                        <h4 class="font-bold text-slate-800 text-xs line-clamp-2 leading-tight group-hover:text-red-600 transition">
                                            <%= item.title %>
                                        </h4>
                                    </div>
                                </a>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
            </aside>
        </div>
    </main>

    <%- include('../admin/partials/footer') %>

    <script>
    async function handleVote(newVote) {
        const articleId = '<%= article._id %>';
        const storageKey = `vote_${articleId}`;
        
        // Lấy trạng thái đã vote từ localStorage (like, dislike hoặc null)
        let currentVote = localStorage.getItem(storageKey); 

        let likeDelta = 0;
        let dislikeDelta = 0;

        // Logic tính toán thay đổi (Delta)
        if (currentVote === newVote) {
            // Nếu bấm lại chính cái đang chọn -> Toggle Off (Hủy)
            if (newVote === 'like') likeDelta = -1;
            else dislikeDelta = -1;
            currentVote = null;
        } else {
            // Nếu đang Like mà bấm Dislike (hoặc ngược lại) -> Phải trừ cái cũ, cộng cái mới
            if (currentVote === 'like') likeDelta = -1;
            if (currentVote === 'dislike') dislikeDelta = -1;

            if (newVote === 'like') likeDelta += 1;
            if (newVote === 'dislike') dislikeDelta += 1;
            currentVote = newVote;
        }

        try {
            // Gửi Delta lên server để server tự cộng trừ trong Database
            const response = await fetch(`/article/${articleId}/vote`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ likeDelta, dislikeDelta })
            });
            const data = await response.json();
            
            if (data.success) {
                // Cập nhật số hiển thị
                document.getElementById('like-count').innerText = data.likes;
                document.getElementById('dislike-count').innerText = data.dislikes;
                
                // Lưu trạng thái mới vào localStorage
                if (currentVote) localStorage.setItem(storageKey, currentVote);
                else localStorage.removeItem(storageKey);
                
                // Cập nhật màu sắc nút bấm
                updateUI(currentVote);
            }
        } catch (err) {
            console.error("Lỗi vote rồi mạy:", err);
        }
    }

    function updateUI(status) {
        const iconLike = document.getElementById('icon-like');
        const iconDislike = document.getElementById('icon-dislike');

        // Reset class
        iconLike.classList.remove('active-like');
        iconDislike.classList.remove('active-dislike');

        // Thêm class active tùy theo trạng thái
        if (status === 'like') iconLike.classList.add('active-like');
        if (status === 'dislike') iconDislike.classList.add('active-dislike');
    }

    // Khi load trang, kiểm tra xem máy này đã vote chưa để tô màu nút
    window.addEventListener('DOMContentLoaded', () => {
        const currentVote = localStorage.getItem(`vote_<%= article._id %>`);
        updateUI(currentVote);
    });
    </script>
</body>
</html>