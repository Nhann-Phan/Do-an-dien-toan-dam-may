<%- include('../admin/partials/header', { title: title }) %>

<body class="bg-slate-50">
    <main class="max-w-7xl mx-auto px-4 py-12">
        <h2 class="text-xl font-black italic uppercase mb-10 border-l-8 border-red-600 pl-6">
            Kết quả tìm kiếm cho: "<span class="text-red-600"><%= query %></span>"
        </h2>

        <% if (articles.length > 0) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% articles.forEach(item => { %>
                    <a href="/article/<%= item._id %>" class="group bg-white rounded-[2rem] overflow-hidden shadow-lg border border-slate-100 hover:-translate-y-2 transition duration-500">
                        <div class="h-56 overflow-hidden">
                            <img src="<%= item.image_url %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
                        </div>
                        <div class="p-6">
                            <span class="text-[10px] font-black text-red-600 uppercase tracking-widest"><%= item.category %></span>
                            <h4 class="text-lg font-black text-slate-800 mt-2 line-clamp-2 leading-tight group-hover:text-red-600 transition"><%= item.title %></h4>
                        </div>
                    </a>
                <% }) %>
            </div>

            <div class="mt-16 flex justify-center items-center space-x-4">
                
                <% if (currentPage > 1) { %>
                    <a href="/search?keyword=<%= query %>&page=<%= currentPage - 1 %>" 
                       class="px-6 py-3 bg-white border border-slate-200 rounded-2xl font-black text-xs uppercase hover:bg-red-600 hover:text-white transition shadow-sm">
                        <i class="bi bi-chevron-left mr-1"></i> Trước
                    </a>
                <% } %>

                <div class="px-6 py-3 bg-slate-100 rounded-2xl font-black text-slate-400 text-[10px] uppercase tracking-widest">
                    Trang <%= currentPage %> / <%= totalPages %>
                </div>

                <% if (currentPage < totalPages) { %>
                    <a href="/search?keyword=<%= query %>&page=<%= currentPage + 1 %>" 
                       class="px-6 py-3 bg-white border border-slate-200 rounded-2xl font-black text-xs uppercase hover:bg-red-600 hover:text-white transition shadow-sm">
                        Sau <i class="bi bi-chevron-right ml-1"></i>
                    </a>
                <% } %>

            </div>

        <% } else { %>
            <div class="text-center py-20 bg-white rounded-[3rem] shadow-sm border border-slate-100">
                <div class="mb-6 relative inline-block">
                    <i class="bi bi-search text-7xl text-slate-100"></i>
                    <i class="bi bi-x-circle-fill text-2xl text-red-500 absolute -bottom-2 -right-2"></i>
                </div>
                <p class="text-slate-400 font-bold italic text-lg">Không tìm thấy bài nào có chữ "<%= query %>" hết Nhân ơi!</p>
                <a href="/" class="inline-block mt-8 px-8 py-3 bg-slate-900 text-white rounded-full font-black text-xs uppercase tracking-widest hover:bg-red-600 transition shadow-lg">
                    Quay về trang chủ
                </a>
            </div>
        <% } %>
    </main>
</body>

<%- include('../admin/partials/footer') %>