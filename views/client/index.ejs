    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <main class="max-w-7xl mx-auto px-4 py-10">

        <section class="mb-20 overflow-hidden">
            <span class="text-lg font-black uppercase italic mb-4 block"> TIN MỚI CẬP NHẬT </span>
                <div class="swiper latestSwiper">
                <div class="swiper-wrapper">
                    <% latestArticles.forEach(item => { %>
                        <div class="swiper-slide">
                            <a href="/article/<%= item._id %>" class="group block relative rounded-[2rem] overflow-hidden shadow-xl aspect-[3/4]">
                                <img src="<%= item.image_url %>" class="w-full h-full object-cover transition duration-700 group-hover:scale-110">
                                <div class="absolute inset-0 news-card-gradient"></div>
                                <div class="absolute bottom-0 p-6">
                                    <span class="bg-white/20 backdrop-blur-md text-white text-[8px] px-2 py-1 rounded font-black uppercase mb-3 inline-block"><%= item.category %></span>
                                    <h3 class="text-white font-black text-sm leading-tight italic line-clamp-3"><%= item.title %></h3>
                                </div>
                            </a>
                        </div>
                    <% }) %>
                </div>
                </div>
        </section>

        <% if (typeof topArticle !== 'undefined' && topArticle) { %>
