<%- include('../admin/partials/header', { title: 'Tuổi Trẻ Cười' }) %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
    /* Thêm cái này để fix lỗi Swiper bị tràn hoặc lệch */
    .swiper { width: 100%; height: 100%; }
    .line-clamp-2 { display: -webkit-box; line-clamp: 2; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .news-card-gradient { background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%); }
</style>

<div class="bg-white min-h-screen font-sans pt-5" x-data="{ open: false }">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <main class="max-w-7xl mx-auto px-4 py-6">
        <section class="mb-16">
            <span class="text-lg font-black uppercase italic mb-6 block underline decoration-red-600 decoration-4 underline-offset-8"> 
                TIN MỚI CẬP NHẬT 
            </span>
            
            <div class="relative">
                <div class="swiper latestSwiper">
                    <div class="swiper-wrapper">
                        <% latestArticles.forEach(item => { %>
                            <div class="swiper-slide">
                                <a href="/article/<%= item._id %>" class="group block relative rounded-[2.5rem] overflow-hidden shadow-lg aspect-[3/4.5]">
                                    <img src="<%= item.image_url %>" class="w-full h-full object-cover transition duration-700 group-hover:scale-110">
                                    <div class="absolute inset-0 news-card-gradient"></div>
                                    <div class="absolute bottom-0 p-6 w-full">
                                        <object>
                                            <a href="/category/<%= item.category %>" class="bg-red-600 text-white text-[8px] px-2 py-1 rounded font-black uppercase mb-3 inline-block hover:bg-white hover:text-red-600 transition">
                                                <%= item.category %>
                                            </a>
                                        </object>
                                        <h3 class="text-white font-black text-sm leading-tight italic line-clamp-3"><%= item.title %></h3>
                                    </div>
                                </a>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </section>

        <% if (typeof sections !== 'undefined') { %>
            <% sections.forEach(section => { %>
                <% if(section.list && section.list.length > 0) { %>
                <section id="<%= section.name %>" class="mb-24">
                    <div class="flex items-center justify-between mb-10 border-b-2 border-slate-100 pb-4">
                        <div class="flex items-center space-x-3">
                            <img src="<%= section.icon %>" class="w-10 h-10 object-contain">
                            <a href="/category/<%= section.name %>" class="hover:text-red-600 transition">
                                <h2 class="text-3xl font-black uppercase italic tracking-tighter text-slate-800"><%= section.name %></h2>
                            </a>
                        </div>
                        <a href="/category/<%= section.name %>" class="text-[10px] font-black uppercase text-slate-400 hover:text-red-600 transition flex items-center">
                            Xem tất cả <i class="bi bi-arrow-right ml-2"></i>
                        </a>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                        <% section.list.forEach(item => { %>
                            <a href="/article/<%= item._id %>" class="group block">
                                <article>
                                    <div class="relative overflow-hidden rounded-[2rem] shadow-lg shadow-slate-200/50 mb-5 bg-slate-100 aspect-video">
                                        <img src="<%= item.image_url %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                                        <div class="absolute top-4 left-4">
                                            <object>
                                                <a href="/category/<%= item.category %>" class="px-3 py-1 bg-white/95 text-[9px] font-black rounded-lg shadow-sm uppercase hover:bg-red-600 hover:text-white transition">
                                                    <%= item.category %>
                                                </a>
                                            </object>
                                        </div>
                                    </div>
                                    <h3 class="font-bold text-slate-800 leading-snug text-md line-clamp-2 group-hover:text-red-600 transition px-1"><%= item.title %></h3>
                                </article>
                            </a>
                        <% }) %>
                    </div>
                </section>
                <% } %>
            <% }) %>
        <% } %>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    // Đợi DOM load xong hoàn toàn mới chạy Swiper
    document.addEventListener('DOMContentLoaded', function () {
        new Swiper(".latestSwiper", {
            slidesPerView: 2,
            spaceBetween: 15, // Giảm khoảng cách lại chút cho đẹp
            loop: true,
            centeredSlides: false, // Để false để nó không bị đẩy ra giữa màn hình
            grabCursor: true,
            autoplay: { 
                delay: 3500, 
                disableOnInteraction: false 
            },
            breakpoints: { 
                640: { slidesPerView: 3 },
                1024: { slidesPerView: 5 } 
            }
        });
    });
</script>

<%- include('../admin/partials/footer') %>